APP_NAME=Vestix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://vestix.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optioneel: Resend in productie (zie forge/production.env.example)
# RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_RATE_LIMIT_DELAY=15

POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
POLYGON_RATE_LIMIT_DELAY=13
POLYGON_ESTIMATED_CALLS_PER_POSITION=2

FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_RATE_LIMIT_DELAY=1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optioneel; standaard gebruikt filament-socialite {APP_URL}/admin/oauth/callback/google
# GOOGLE_REDIRECT_URI=

VESTIX_ADMIN_NOTIFICATION_EMAILS=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# EOD sync: vestix:fetch-data (23:00 Europe/Amsterdam) zie forge/production.env.example en forge/setup-checklist.txt
# PHP_BINARY=/usr/bin/php8.3
# Data migreren: php artisan vestix:export-data (lokaal) → vestix:import-data (productie)
# Eerste admin (zonder import): php artisan vestix:create-user you@example.com --password=... --super-admin
# Post-deploy: php artisan vestix:smoke-test
# Quote-vergelijking: php artisan vestix:compare-market-quotes TKO
# Scheduler cron: * * * * * cd /path/to/vestix && php artisan schedule:run >> /dev/null 2>&1
